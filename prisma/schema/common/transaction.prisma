// ============================================================
// common/transaction.prisma
//
// Generic transaction / ledger model — opt-in.
// Use for payment records, credit movements, or any
// financial event that needs an immutable audit trail.
//
// Rows should never be updated or deleted (append-only).
// ============================================================

model Transaction {
  id          String  @id @default(uuid())
  userId      String
  type        String // "payment" | "refund" | "credit" | "debit" — extend per project
  amount      Int // store in smallest currency unit (cents)
  currency    String  @default("USD")
  status      String // "pending" | "success" | "failed" — extend per project
  referenceId String? // external ref: Stripe charge ID, order ID, etc.
  metadata    Json? // any extra context

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([referenceId])
  @@index([createdAt])
  @@map("transactions")
}
