// ============================================================
// core/two-factor.prisma
//
// Multi-method 2FA. A user can enroll any of:
//   TOTP      → authenticator app (secret stored, AES-GCM at rest)
//   EMAIL_OTP → 6-digit code over email (no persistent secret;
//               codes live in Redis under otp:email:*)
//   SMS_OTP   → 6-digit code over phone (no persistent secret;
//               codes live in Redis under otp:sms:*)
//
// Backup codes are per-user (recovery codes), not per-method. They work as
// a last-resort regardless of which factor failed, matching industry norms.
// ============================================================

model TwoFactorMethod {
  id          String              @id @default(uuid())
  userId      String
  type        TwoFactorMethodType
  isEnabled   Boolean             @default(false)
  isPrimary   Boolean             @default(false)
  secret      String? // TOTP only — AES-256-GCM (iv:tag:ciphertext)
  destination String? // email/phone snapshot at enrollment for OTP
  lastUsedAt  DateTime?
  verifiedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
  @@index([userId])
  @@map("two_factor_methods")
}

model TwoFactorBackupCode {
  id       String    @id @default(uuid())
  userId   String
  codeHash String    @unique // SHA-256 of plaintext backup code
  usedAt   DateTime? // null = still valid

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("two_factor_backup_codes")
}
