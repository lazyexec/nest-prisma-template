// ============================================================
// core/credential.prisma
//
// One row per auth provider per user.
//
// EMAIL  → providerId = email address, passwordHash set
// GOOGLE → providerId = Google "sub", passwordHash null
// APPLE  → providerId = Apple "sub",  passwordHash null
// ============================================================

model Credential {
  id           String       @id @default(uuid())
  userId       String
  provider     AuthProvider @default(EMAIL)
  providerId   String // email address (EMAIL) or OAuth sub (GOOGLE/APPLE)
  passwordHash String? // bcrypt — EMAIL only, null for OAuth
  lastUsedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerId]) // one OAuth account linked globally at most once
  @@unique([userId, provider]) // one credential per provider per user
  @@map("credentials")
}
