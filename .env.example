# APPLICATION
APP_NAME=nest-prisma-template
PORT=3000
NODE_ENV=development
DEBUG=false
BACKEND_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173
RATE_LIMIT_TTL=60
RATE_LIMIT_LIMIT=100

# DATABASE
DATABASE_URL=postgresql://postgres:password@localhost:5432/postgres
DATABASE_POOL_SIZE=10

# REDIS (required)
REDIS_URL=redis://localhost:6379
REDIS_TTL_SECONDS=300
REDIS_KEY_PREFIX=nest-prisma-template:

# AUTH — JWT
JWT_ACCESS_SECRET=replace-with-a-strong-access-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace-with-a-strong-refresh-secret
JWT_REFRESH_EXPIRES_IN=30d

# AUTH — encryption (32-byte base64 used for TOTP secret at rest)
AUTH_ENCRYPTION_KEY=replace-with-a-32-byte-base64-key

# AUTH — login lockout & token TTLs
AUTH_LOGIN_MAX_FAILS=10
AUTH_LOGIN_LOCKOUT_TTL_SECONDS=900
AUTH_PASSWORD_RESET_TTL_SECONDS=1800
AUTH_EMAIL_VERIFY_TTL_SECONDS=86400
AUTH_2FA_CHALLENGE_TTL_SECONDS=300

# OTP
OTP_LENGTH=6
OTP_EMAIL_TTL_SECONDS=600
OTP_SMS_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=60

# TOTP (authenticator app)
TOTP_ISSUER=NestPrismaTemplate
TOTP_WINDOW=1

# MAIL — Gmail SMTP (use an App Password, not your account password)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=your-gmail@gmail.com
MAIL_PASS=your-16-char-app-password
MAIL_FROM="NestPrismaTemplate <your-gmail@gmail.com>"

# SMS — Twilio (optional; leave blank to disable SMS OTP)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# OAUTH — server-side ID-token verification only.
# Client (web/iOS/Android) obtains an ID token from Google/Apple and POSTs it
# to /auth/oauth/{provider}. Backend verifies signature + audience.
# Supply a comma-separated list of accepted client IDs (audiences).
GOOGLE_CLIENT_IDS=
APPLE_CLIENT_IDS=
